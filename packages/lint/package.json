{
  "name": "oculus-lint",
  "version": "0.1.0",
  "description": "Linter integration for oculus — runs on changed files at turn end",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "oculus-native": "file:../native"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "vitest": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "files": ["src/"]
}
